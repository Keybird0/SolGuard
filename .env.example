# =====================================================
# SolGuard Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to git.
# =====================================================

# ----------------- LLM Provider ----------------------
# SolGuard reads these from .env for server-side / Python-skill calls.
# OH CLI (`oh -p`) is configured separately via ~/.openharness/settings.json +
# `~/.openharness/credentials.json` (see Phase1 §P1.1.2). The two paths
# should agree on provider/model to avoid behavior drift.
#
# Active path (Phase 1+): OrbitAI OpenAI-compatible gateway (/v1, gpt-5.4)
#   - `LLM_BASE_URL` below is the OpenAI-compatible endpoint
#   - Fill `OPENAI_API_KEY` with the OrbitAI key
#   - Leave `ANTHROPIC_API_KEY` blank unless you switch provider=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4
LLM_BASE_URL=https://aiapi.orbitai.global/v1
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ----------------- Solana / Payment ------------------
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_SERVICE_WALLET=
AUDIT_PRICE_SOL=0.01
PAYMENT_TIMEOUT_MS=600000

# ----------------- Email (Nodemailer) ----------------
# goat-track has validated smtp.qq.com:465 + 16-char App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SolGuard <noreply@solguard.xyz>"
EMAIL_REPLY_TO=
# BCC every customer audit email to this address for operator archival.
EMAIL_BCC_OPERATOR=

# ----------------- Server ----------------------------
PORT=3000
NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://solguard.xyz

# ----------------- Agent --------------------------
OH_CLI_PATH=oh
OH_SKILL_DIR=
AGENT_CALLBACK_TOKEN=change-me-to-random-string
AGENT_TIMEOUT_MS=600000

# ----------------- Storage ---------------------------
DATA_DIR=./data
TASK_STORE=in-memory
# Options: in-memory | file-json

# ----------------- Lark / Feishu Webhook -------------
# Three-stage operator notifications (submitted / paid / completed|failed).
# Leave LARK_WEBHOOK_URL blank to silence all cards.
# Example: https://open.feishu.cn/open-apis/bot/v2/hook/<uuid>
LARK_WEBHOOK_URL=
LARK_NOTIFY_STAGES=submitted,paid,completed,failed
LARK_ENV_TAG=local

# ----------------- Observability ---------------------
SENTRY_DSN=
# Legacy placeholder; Phase 5 switched to LARK_WEBHOOK_URL above.
FEISHU_WEBHOOK=
