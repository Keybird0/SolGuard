# =====================================================
# SolGuard Environment Variables
# Copy this file to .env and fill in real values.
# DO NOT commit .env to git.
# =====================================================

# ----------------- LLM Provider ----------------------
# Choose one or both. SolGuard uses anthropic by default.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096

# ----------------- Solana / Payment ------------------
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_SERVICE_WALLET=
AUDIT_PRICE_SOL=0.01
PAYMENT_TIMEOUT_MS=600000

# ----------------- Email (Nodemailer) ----------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SolGuard <noreply@solguard.xyz>"
EMAIL_REPLY_TO=

# ----------------- Server ----------------------------
PORT=3000
NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,https://solguard.xyz

# ----------------- Agent --------------------------
OH_CLI_PATH=oh
OH_SKILL_DIR=
AGENT_CALLBACK_TOKEN=change-me-to-random-string
AGENT_TIMEOUT_MS=600000

# ----------------- Storage ---------------------------
DATA_DIR=./data
TASK_STORE=in-memory
# Options: in-memory | file-json

# ----------------- Observability ---------------------
SENTRY_DSN=
FEISHU_WEBHOOK=
