# ============ Python (uv-managed) ============
# Commit pyproject.toml, uv.lock and .python-version — they ARE the
# source of truth for the Python environment. Everything below is
# derivable/generated and therefore ignored.
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.Python
.venv/
venv/
env/
.mypy_cache/
.pytest_cache/
.ruff_cache/
.uv-cache/
.coverage
coverage.xml
htmlcov/

# ============ Node / TypeScript ============
node_modules/
dist/
build/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.eslintcache

# ============ Env & Secrets ============
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
.local-notes.md

# ============ Data / Outputs ============
data/
outputs/**
!outputs/.gitkeep
logs/
*.log
.DS_Store

# ============ External References ============
references/
.cache/
llm-cache/
.llm-cache/

# ============ Vercel ============
.vercel/

