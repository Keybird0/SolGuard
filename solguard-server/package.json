{
  "name": "solguard-server",
  "version": "0.1.0",
  "description": "SolGuard - Express + TypeScript backend that orchestrates the Solana security audit agent.",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts' 'public/**/*.{js,html,css}'",
    "format:check": "prettier --check 'src/**/*.ts' 'public/**/*.{js,html,css}'",
    "test": "node --test --import tsx 'src/**/*.test.ts'",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "solana",
    "security",
    "audit",
    "ai",
    "smart-contract"
  ],
  "author": "SolGuard Contributors",
  "license": "MIT",
  "dependencies": {
    "@solana/pay": "^0.2.6",
    "@solana/web3.js": "^1.95.0",
    "bignumber.js": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "nodemailer": "^6.9.14",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^6.4.15",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
