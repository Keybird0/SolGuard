# Server
PORT=3000
NODE_ENV=development
APP_VERSION=0.1.0
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
PUBLIC_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# LLM (at least one key)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Solana / Solana Pay
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_SERVICE_WALLET=
AUDIT_PRICE_SOL=0.01
PAYMENT_TIMEOUT_MS=600000
PAYMENT_POLL_INTERVAL_MS=5000
# Plan B: skip payment entirely (local dev / Pay outage)
FREE_AUDIT=false

# Email (SMTP). Leave blank to only log instead of sending.
# goat-track has validated smtp.qq.com:465 + 16-char App Password; gmail/163 also work.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="SolGuard <noreply@solguard.xyz>"
EMAIL_REPLY_TO=
# BCC every customer mail to this address for operator archival. Leave blank to disable.
EMAIL_BCC_OPERATOR=

# Lark / Feishu incoming webhook — operator-side lifecycle notifications.
# Three-stage cards: Stage1 submitted, Stage2 paid, Stage3 completed/failed.
# Leave LARK_WEBHOOK_URL blank to silence all cards (module degrades to a no-op).
# Example: https://open.feishu.cn/open-apis/bot/v2/hook/<uuid>
LARK_WEBHOOK_URL=
# Whitelist of stages to push. Blank or comma-separated list of:
#   submitted | paid | completed | failed
LARK_NOTIFY_STAGES=submitted,paid,completed,failed
# Environment tag shown at the top of every card (local / staging / prod).
LARK_ENV_TAG=local

# OpenHarness Agent CLI
OH_CLI_PATH=oh
OH_SKILL_DIR=../skill/solana-security-audit-skill
OH_OUTPUT_FORMAT=json-stream
AGENT_CALLBACK_TOKEN=change-me-to-random-string
# When true, /api/audit/:id/complete requires X-Agent-Signature (HMAC-SHA256)
# and falls back to X-Agent-Token only if signature is missing. In production
# the server enforces HMAC regardless of this flag unless explicitly disabled.
AGENT_HMAC_REQUIRED=false
AGENT_TIMEOUT_MS=600000
AUDIT_WORKDIR=./data/workdir
AUDIT_OUTPUT_ROOT=./data/outputs

# Dual-path runner (oh CLI + python fallback)
RUNNER_FALLBACK_TO_PYTHON=true
PYTHON_BIN=uv
PYTHON_RUN_AUDIT_SCRIPT=../skill/solana-security-audit-skill/scripts/run_audit.py
GIT_BIN=git
INPUT_NORMALIZER_TIMEOUT_MS=120000

# Rate limiting (disabled by default; enable in prod)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Storage
DATA_DIR=./data
TASK_STORE=in-memory

# Optional webhook for feedback alerts (Slack / Feishu incoming webhook)
FEEDBACK_WEBHOOK_URL=
